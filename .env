VITE_ONESIGNAL_APP_ID=ad91611f-1d9f-4ba8-a077-e05b5bd55108

# PostgreSQL local (Docker). Para usar um banco Neon na nuvem, basta trocar a URL
# pela connection string do Neon (o driver é detectado automaticamente).
DATABASE_URL=postgresql://astec:astec@localhost:5433/astec

# Porta do servidor (API + cliente)
PORT=5000

# Segredo para assinar os tokens JWT (troque por um valor forte em produção)
SESSION_SECRET=dev-local-astec-secret-change-me-9f3a2b7c1d-mfa-test-2026

# Azure AD / Microsoft 365 (MFA com OAuth)
# Se não tiver, deixe em branco para usar modo demo
AZURE_CLIENT_ID=test-client-id-local
AZURE_TENANT_ID=common
AZURE_CLIENT_SECRET=test-secret-local

# URLs para OAuth
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
